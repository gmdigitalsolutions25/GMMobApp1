      "android": {
        "buildType": "app-bundle",
        "image": "latest"
      },
      "env": {
        "NODE_ENV": "production",
        "DATABASE_URL": "postgresql://qaraj_app:qaraj_app7162381637@servicewebhooks.cp08geg2csn4.us-east-1.rds.amazonaws.com:5432/qaraj"
