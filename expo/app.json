{
  "expo": {
    "name": "Qaraj",
    "slug": "qaraj",
    "version": "1.0.21",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "qaraj",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E1E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "az.qaraj.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow Qaraj to access your photos to add vehicle images.",
        "NSCameraUsageDescription": "Allow Qaraj to access your camera to take vehicle photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0E1E"
      },
      "package": "az.qaraj.app",
      "versionCode": 21,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "SCHEDULE_EXACT_ALARM"
      ],
      "useNextNotificationsApi": true
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Qaraj accesses your photos to let you add vehicle images."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#00D4AA",
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}