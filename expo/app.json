{
  "expo": {
    "name": "Qaraj",
    "slug": "qaraj",
    "version": "1.2.8",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "qaraj",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E1E"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "az.qaraj.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow Qaraj to access your photos to add vehicle images.",
        "NSCameraUsageDescription": "Allow Qaraj to access your camera to take vehicle photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0E1E"
      },
      "package": "az.qaraj.app",
      "googleServicesFile": "./google-services.json",
      "versionCode": 45,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Qaraj accesses your photos to let you add vehicle images."
        }
      ],
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "76b96668-e97c-4609-a448-d655ae30ec2d"
      }
    },
    "owner": "elnurhasan"
  }
}
