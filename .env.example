# Qaraj Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ── Database ───────────────────────────────────────────────────────────────────
# PostgreSQL connection string (AWS RDS, Supabase, Neon, etc.)
DATABASE_URL=postgresql://qaraj_app:your_password@your-db-host:5432/qaraj

# ── AI ─────────────────────────────────────────────────────────────────────────
# OpenAI API key for AI spare parts search
OPENAI_API_KEY=sk-your-openai-api-key

# ── Server ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080

# ── Expo / EAS ─────────────────────────────────────────────────────────────────
# Your Expo project ID from eas.json / app.json
EXPO_PROJECT_ID=your-eas-project-id
