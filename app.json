{
  "expo": {
    "name": "Qaraj",
    "slug": "qaraj",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "qaraj",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a1a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "az.qaraj.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow Qaraj to access your photos to add vehicle images.",
        "NSCameraUsageDescription": "Allow Qaraj to access your camera to take vehicle photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1a1a1a"
      },
      "package": "az.qaraj.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Qaraj accesses your photos to let you add vehicle images."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
